{
  "name": "@kiln/desktop",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:sidecar": "node --experimental-sqlite dist-sidecar/main.js",
    "build": "pnpm build:sidecar && vite build",
    "build:sidecar": "tsup",
    "tauri": "tauri",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:binary:bundle": "tsup --config tsup.binary.config.ts",
    "build:binary": "pnpm build:binary:bundle && node scripts/build-binary.mjs"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@hono/node-server": "^2.0.8",
    "@kiln/agents": "workspace:*",
    "@kiln/core": "workspace:*",
    "@tanstack/react-query": "^5.90.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.11.2",
    "hono": "^4.12.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vitest": "^2.1.8"
  }
}
